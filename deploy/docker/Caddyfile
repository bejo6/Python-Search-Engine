# ╔══════════════════════════════════════════════════════════╗
# ║  Caddy Reverse Proxy Configuration                       ║
# ║                                                           ║
# ║  GANTI:                                                  ║
# ║  1. search.example.com -> domain kamu                    ║
# ║  2. YOUR_SECRET_API_KEY -> API key kamu                  ║
# ╚══════════════════════════════════════════════════════════╝

# ─── Main site: requires API key ───
search.example.com {
    # Auto HTTPS (Caddy handles SSL cert via Let's Encrypt)

    # ─── Logging ───
    log {
        output stdout
        format json
        level INFO
    }

    # ─── API Key Auth ───
    # Request harus punya header: X-API-Key: YOUR_SECRET_API_KEY
    @noapikey {
        not header X-API-Key YOUR_SECRET_API_KEY
    }
    respond @noapikey 401

    # ─── Rate Limiting (per IP, 30 req/minute untuk API) ───
    # Optional: uncomment kalau mau rate limit per IP
    # rate_limit {
    #     zone {
    #         key {remote_host}
    #         events 30
    #         window 1m
    #     }
    # }

    # ─── Reverse Proxy ke SearXNG ───
    reverse_proxy searxng:8080 {
        # Forward real client IP
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Health check
        health_uri /healthz
        health_interval 30s
        health_timeout 5s
    }

    # ─── Security Headers ───
    header {
        # Remove Caddy identifying header
        -Server
        # Basic security headers
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
    }

    # ─── Compression ───
    encode zstd gzip

    # ─── HSTS for HTTPS ───
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
}

# ─── Alternative: HTTP Basic Auth (simpler, no custom header) ───
# Uncomment block ini dan comment block di atas kalau mau Basic Auth

