# ╔══════════════════════════════════════════════════════════╗
# ║  Caddyfile - SearXNG Reverse Proxy (Non-Docker)          ║
# ║                                                           ║
# ║  GANTI:                                                   ║
# ║  1. search.example.com  ->  domain kamu                  ║
# ║  2. YOUR_SECRET_API_KEY ->  API key yang kamu pilih      ║
# ╚══════════════════════════════════════════════════════════╝

search.example.com {
    # Auto HTTPS via Let's Encrypt
    tls admin@example.com

    # --- API Key Auth ---
    # Request harus punya header: X-API-Key: YOUR_SECRET_API_KEY
    @noapikey {
        not header X-API-Key YOUR_SECRET_API_KEY
    }
    respond @noapikey 401

    # --- Reverse Proxy ke SearXNG (localhost:8080) ---
    reverse_proxy 127.0.0.1:8080 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # --- Security Headers ---
    header {
        -Server
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
    }

    # --- Compression ---
    encode zstd gzip

    # --- Logging ---
    log {
        output stdout
        format json
        level INFO
    }
}
